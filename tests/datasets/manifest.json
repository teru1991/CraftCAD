{
  "version": "1.0.0",
  "datasets": [
    {
      "id": "io_roundtrip_smoke",
      "description": "Smoke: import/export round-trip (SVG/JSON) minimal fixtures.",
      "seed": 1,
      "determinism": { "epsilon": 0.0001, "round_step": 0.0001, "ordering_tag": "io_smoke_v1" },
      "limits_ref": "default",
      "inputs": [
        { "kind": "svg", "path": "tests/golden/inputs/io/svg/min_rect.svg" },
        { "kind": "json", "path": "tests/golden/inputs/io/json/min_rect.json" }
      ],
      "expected": [
        { "kind": "normalized_model", "path": "tests/golden/expected/io_roundtrip_smoke/normalized_model.json", "compare": "json_struct" },
        { "kind": "warnings", "path": "tests/golden/expected/io_roundtrip_smoke/warnings.json", "compare": "reason_codes" }
      ],
      "tags": ["smoke"]
    },
    {
      "id": "diycad_open_save_smoke",
      "description": "Smoke: open/save .diycad minimal project fixture.",
      "seed": 2,
      "determinism": { "epsilon": 0.0001, "round_step": 0.0001, "ordering_tag": "diycad_smoke_v1" },
      "limits_ref": "default",
      "inputs": [
        { "kind": "diycad", "path": "tests/golden/inputs/projects/min_project.diycad" }
      ],
      "expected": [
        { "kind": "open_result", "path": "tests/golden/expected/diycad_open_save_smoke/open_result.json", "compare": "json_struct" },
        { "kind": "warnings", "path": "tests/golden/expected/diycad_open_save_smoke/warnings.json", "compare": "reason_codes" }
      ],
      "tags": ["smoke"]
    }
  ]
}
