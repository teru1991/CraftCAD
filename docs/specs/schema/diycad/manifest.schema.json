{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "diycad://schema/manifest.schema.json",
  "title": "DIYCAD Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "app_version", "created_at", "updated_at", "unit", "entrypoints"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "app_version": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "unit": { "type": "string", "enum": ["mm", "inch"] },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document"],
      "properties": {
        "document": { "type": "string", "minLength": 1 }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "determinism_tag": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "seed": { "type": "integer" },
        "eps": { "type": "number" },
        "rounding_decimals": { "type": "integer", "minimum": 0, "maximum": 12 }
      }
    },
    "content_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "size", "sha256"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "size": { "type": "integer", "minimum": 0 },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          }
        }
      }
    }
  }
}
