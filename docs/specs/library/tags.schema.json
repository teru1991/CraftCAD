{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://craftcad.local/schema/library/tags.schema.json",
  "title": "CraftCAD Tags Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "max_len", "forbidden_patterns", "normalize"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "max_len": { "type": "integer", "minimum": 1, "maximum": 64 },
    "forbidden_patterns": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "normalize": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lowercase", "trim", "collapse_spaces", "remove_zenkaku_spaces"],
      "properties": {
        "lowercase": { "type": "boolean" },
        "trim": { "type": "boolean" },
        "collapse_spaces": { "type": "boolean" },
        "remove_zenkaku_spaces": { "type": "boolean" }
      }
    }
  },
  "schema_version": 1,
  "max_len": 32,
  "forbidden_patterns": ["/", "\\\\", "\\.\\.", ":", "\\0"],
  "normalize": {
    "lowercase": true,
    "trim": true,
    "collapse_spaces": true,
    "remove_zenkaku_spaces": true
  }
}
