{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CraftCAD i18n Resource Schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "__meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "patternProperties": {
    "^UI\\.[A-Z0-9_]+\\.[A-Z0-9_]+\\.[A-Z0-9_\\.]+$": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    }
  }
}
