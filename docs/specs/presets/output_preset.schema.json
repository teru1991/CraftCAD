{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://craftcad.local/schema/presets/output_preset.schema.json",
  "title": "OutputPreset",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "schema_version", "preferred_formats", "origin_policy", "tags"],
  "properties": {
    "id": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9][a-z0-9_\\-]*$" },
    "version": { "type": "string", "minLength": 1, "maxLength": 32 },
    "schema_version": { "type": "integer", "minimum": 1 },
    "display_name_key": { "type": "string", "minLength": 1, "maxLength": 128 },
    "tags": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 64 }
    },
    "created_by": { "type": "string", "enum": ["builtin", "user", "project"] },
    "updated_at": { "type": "string" },
    "preferred_formats": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "type": "string", "enum": ["svg", "dxf", "json", "pdf", "png"] }
    },
    "origin_policy": { "type": "string", "enum": ["keep", "move_to_zero"] },
    "postprocess_policy_id": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9][a-z0-9_\\-]*$" },
    "bw_mode_default": { "type": "boolean" }
  }
}
