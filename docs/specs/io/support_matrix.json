{
  "schema_version": 1,
  "formats": ["dxf", "svg", "json"],
  "directions": ["import", "export"],
  "levels": ["supported", "best_effort", "not_supported"],
  "matrix": [
    { "format": "dxf", "direction": "import", "feature": "entity_line", "level": "supported" },
    { "format": "dxf", "direction": "import", "feature": "entity_polyline", "level": "supported" },
    { "format": "dxf", "direction": "import", "feature": "entity_arc", "level": "supported" },
    { "format": "dxf", "direction": "import", "feature": "entity_circle", "level": "supported" },
    {
      "format": "dxf",
      "direction": "import",
      "feature": "entity_text",
      "level": "best_effort",
      "action": "fallback",
      "reason_codes": ["IO_TEXT_FALLBACK_FONT", "IO_FALLBACK_024"],
      "notes": "DXF TEXT/MTEXT のフォント等は環境差が大きいため、hintとして扱う。"
    },
    {
      "format": "dxf",
      "direction": "import",
      "feature": "entity_spline",
      "level": "best_effort",
      "action": "approx",
      "reason_codes": ["IO_CURVE_APPROX_APPLIED", "IO_UNSUPPORTED_ENTITY_DXF_SPLINE"],
      "notes": "SPLINE は cubic へ変換し、必要ならapproxでポリライン化する（curve_approx_policy に従う）。"
    },
    {
      "format": "dxf",
      "direction": "import",
      "feature": "entity_hatch",
      "level": "not_supported",
      "action": "drop",
      "reason_codes": ["IO_HATCH_SIMPLIFIED"],
      "notes": "HATCH は未対応。必要なら別ツールで展開してから再試行。"
    },

    { "format": "svg", "direction": "import", "feature": "entity_path", "level": "supported" },
    { "format": "svg", "direction": "import", "feature": "entity_line", "level": "supported" },
    { "format": "svg", "direction": "import", "feature": "entity_polyline", "level": "supported" },
    { "format": "svg", "direction": "import", "feature": "entity_polygon", "level": "supported" },
    { "format": "svg", "direction": "import", "feature": "entity_circle", "level": "supported" },
    {
      "format": "svg",
      "direction": "import",
      "feature": "entity_path_quadratic_bezier",
      "level": "supported",
      "notes": "Q/T は cubic へ決定的に変換して保持する（形状は保持される）。"
    },
    {
      "format": "svg",
      "direction": "import",
      "feature": "entity_path_elliptical_arc",
      "level": "best_effort",
      "action": "convert_to_cubic",
      "reason_codes": ["IO_CURVE_APPROX_APPLIED"],
      "notes": "SVG A は楕円弧→cubic（<=90deg/seg）に決定的変換して保持。さらに必要ならapproxでポリライン化。"
    },
    {
      "format": "svg",
      "direction": "import",
      "feature": "entity_text",
      "level": "best_effort",
      "action": "fallback",
      "reason_codes": ["IO_TEXT_FALLBACK_FONT"],
      "notes": "フォントはhint。レイアウト完全一致は保証しない。"
    },
    {
      "format": "svg",
      "direction": "import",
      "feature": "attribute_transform",
      "level": "supported",
      "notes": "translate/scale/rotate/matrix を affine として適用する。"
    },
    {
      "format": "svg",
      "direction": "import",
      "feature": "external_reference",
      "level": "not_supported",
      "action": "drop",
      "reason_codes": ["IO_IMAGE_REFERENCE_DROPPED"],
      "notes": "xlink/href 等の外部参照はセキュリティ上遮断。"
    },

    { "format": "json", "direction": "import", "feature": "internal_model_v1", "level": "supported" },
    { "format": "json", "direction": "export", "feature": "internal_model_v1", "level": "supported" },

    {
      "format": "dxf",
      "direction": "export",
      "feature": "entity_cubic_bezier",
      "level": "best_effort",
      "action": "approx",
      "reason_codes": ["IO_CURVE_APPROX_APPLIED"],
      "notes": "DXF出力でBezierは近似。"
    },

    { "format": "svg", "direction": "export", "feature": "entity_path", "level": "supported" },
    {
      "format": "svg",
      "direction": "export",
      "feature": "entity_text",
      "level": "best_effort",
      "action": "fallback",
      "reason_codes": ["IO_TEXT_FALLBACK_FONT"],
      "notes": "SVG text はフォント埋め込み等を行わずhintとして扱う。"
    },
    {
      "format": "svg",
      "direction": "export",
      "feature": "entity_circle",
      "level": "best_effort",
      "action": "approx",
      "reason_codes": ["IO_CURVE_APPROX_APPLIED"],
      "notes": "circle は approx で polyline 化して path として出力する（enable_approx=true推奨）。"
    },
    {
      "format": "svg",
      "direction": "export",
      "feature": "entity_arc",
      "level": "best_effort",
      "action": "approx",
      "reason_codes": ["IO_CURVE_APPROX_APPLIED"],
      "notes": "arc は approx で polyline 化して path として出力する（enable_approx=true推奨）。"
    },
    {
      "format": "svg",
      "direction": "export",
      "feature": "entity_path_unhandled_segment",
      "level": "best_effort",
      "action": "approx",
      "reason_codes": ["IO_CURVE_APPROX_APPLIED"],
      "notes": "未対応segmentは enable_approx で救済する。"
    }
  ]
}
