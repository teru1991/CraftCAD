{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://craftcad.local/schemas/security/sca_allowlist.schema.json",
  "title": "CraftCAD SCA Allowlist (Time-bounded Exceptions)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "exceptions"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "exceptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/exception" },
      "minItems": 0
    }
  },
  "$defs": {
    "exception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rationale", "owner", "expires_on"],
      "properties": {
        "id": { "type": "string", "minLength": 6 },
        "rationale": { "type": "string", "minLength": 10, "maxLength": 4000 },
        "owner": { "type": "string", "minLength": 2, "maxLength": 200 },
        "expires_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    }
  }
}
