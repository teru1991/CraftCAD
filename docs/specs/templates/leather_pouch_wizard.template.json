{
  "template_id": "leather_pouch_wizard",
  "template_version": "1.0.0",
  "schema_version": 1,
  "kind": "leather_pouch",
  "display_name_key": "template.leather_pouch",
  "required_presets": {
    "material_preset_ids": ["leather_2_0mm"],
    "process_preset_ids": ["knife_basic"],
    "output_preset_ids": ["export_svg_laser"]
  },
  "ui_inputs": [
    { "key": "pouch_w_mm", "type": "number", "unit": "mm", "default": 100.0, "min": 30.0, "max": 400.0, "step": 1.0 },
    { "key": "pouch_h_mm", "type": "number", "unit": "mm", "default": 70.0, "min": 30.0, "max": 400.0, "step": 1.0 },
    { "key": "seam_allowance_mm", "type": "number", "unit": "mm", "default": 4.0, "min": 1.0, "max": 20.0, "step": 0.5 },
    { "key": "hole_pitch_mm", "type": "number", "unit": "mm", "default": 4.0, "min": 2.0, "max": 10.0, "step": 0.1 }
  ],
  "generation_steps": [
    { "op": "add_part_rect", "args": { "name": "pouch_body", "w_key": "pouch_w_mm", "h_key": "pouch_h_mm" } },
    { "op": "add_annotation", "args": { "kind": "stitch_pitch", "text": "hole_pitch_mm" } },
    { "op": "recommend_nest", "args": { "material_hint": "leather_2_0mm", "process_hint": "knife_basic" } }
  ],
  "determinism": { "seed_source": "ssot_default" }
}
