{
  "template_id": "shelf_wizard",
  "template_version": "1.0.0",
  "schema_version": 1,
  "kind": "shelf",
  "display_name_key": "template.shelf",
  "required_presets": {
    "material_preset_ids": ["plywood_18mm"],
    "process_preset_ids": ["saw_basic"],
    "output_preset_ids": ["export_json_internal"],
    "hardware_preset_ids": ["dowel_8mm"]
  },
  "ui_inputs": [
    { "key": "width_mm", "type": "number", "unit": "mm", "default": 600.0, "min": 50.0, "max": 2400.0, "step": 1.0 },
    { "key": "depth_mm", "type": "number", "unit": "mm", "default": 300.0, "min": 50.0, "max": 1200.0, "step": 1.0 },
    { "key": "thickness_mm", "type": "number", "unit": "mm", "default": 18.0, "min": 1.0, "max": 100.0, "step": 0.1 },
    { "key": "quantity", "type": "integer", "unit": "count", "default": 1, "min": 1, "max": 100, "step": 1 },
    { "key": "hole_dowel", "type": "bool", "unit": "none", "default": true, "min": false, "max": true, "step": 1 },
    { "key": "dowel_diameter_mm", "type": "number", "unit": "mm", "default": 8.0, "min": 3.0, "max": 20.0, "step": 0.1 },
    { "key": "offset_mm", "type": "number", "unit": "mm", "default": 35.0, "min": 5.0, "max": 200.0, "step": 0.5 }
  ],
  "generation_steps": [
    { "op": "add_part_rect", "args": { "name": "shelf_board", "w_key": "width_mm", "h_key": "depth_mm" } },
    { "op": "add_hole_circle_array", "args": { "enabled_key": "hole_dowel", "part_name": "shelf_board", "diam_key": "dowel_diameter_mm", "offset_key": "offset_mm", "pattern": "4_corners" } },
    { "op": "add_annotation", "args": { "kind": "hole_callout", "enabled_key": "hole_dowel", "text": "dowel_diameter_mm" } },
    { "op": "recommend_nest", "args": { "material_hint": "plywood_18mm", "process_hint": "saw_basic" } }
  ],
  "determinism": { "seed_source": "ssot_default" }
}
