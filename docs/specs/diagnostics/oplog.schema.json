{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://craftcad.local/schemas/diagnostics/oplog.schema.json",
  "title": "CraftCAD OpLog",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "started_at", "actions"],
  "properties": {
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "started_at": { "type": "string", "format": "date-time" },
    "actions": {
      "type": "array",
      "maxItems": 200000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "action_id", "kind", "params_hash", "params_redacted", "affected_ids", "result", "reason_codes"],
        "properties": {
          "seq": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
          "action_id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
          "params_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "params_redacted": { "type": "object" },
          "affected_ids": {
            "type": "array",
            "maxItems": 4096,
            "items": { "type": "string", "minLength": 1, "maxLength": 128 }
          },
          "result": { "type": "string", "enum": ["ok", "failed", "cancelled", "skipped"] },
          "reason_codes": {
            "type": "array",
            "maxItems": 256,
            "items": { "type": "string", "minLength": 1, "maxLength": 128 }
          }
        }
      }
    }
  }
}
