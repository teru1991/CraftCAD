{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://craftcad.local/schemas/diagnostics/joblog.schema.json",
  "title": "CraftCAD JobLog",
  "type": "object",
  "additionalProperties": false,
  "required": ["header", "inputs", "timeline", "reasons", "consent_snapshot"],
  "properties": {
    "header": {
      "type": "object",
      "additionalProperties": false,
      "required": ["joblog_version", "app_version", "schema_version", "os", "arch", "locale", "timezone", "determinism_tag", "limits_profile"],
      "properties": {
        "joblog_version": { "type": "integer", "minimum": 1, "maximum": 9999 },
        "app_version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "build_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "schema_version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "os": { "type": "string", "minLength": 1, "maxLength": 64 },
        "arch": { "type": "string", "minLength": 1, "maxLength": 32 },
        "locale": { "type": "string", "minLength": 1, "maxLength": 32 },
        "timezone": { "type": "string", "minLength": 1, "maxLength": 64 },
        "determinism_tag": {
          "type": "object",
          "additionalProperties": false,
          "required": ["seed", "epsilon", "rounding", "ordering"],
          "properties": {
            "seed": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
            "epsilon": { "type": "number", "exclusiveMinimum": 0.0, "maximum": 0.1 },
            "rounding": { "type": "string", "minLength": 1, "maxLength": 64 },
            "ordering": { "type": "string", "minLength": 1, "maxLength": 128 }
          }
        },
        "limits_profile": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "inputs": {
      "type": "array",
      "maxItems": 4096,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "id", "sha256", "size_bytes", "source_hint_redacted"],
        "properties": {
          "kind": { "type": "string", "minLength": 1, "maxLength": 32 },
          "id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0, "maximum": 1099511627776 },
          "source_hint_redacted": { "type": "string", "minLength": 0, "maxLength": 128 }
        }
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "maxItems": 100000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ts", "action_id", "action_kind", "params_redacted", "result_kind", "reason_codes"],
            "properties": {
              "ts": { "type": "string", "format": "date-time" },
              "action_id": { "type": "string", "minLength": 1, "maxLength": 128 },
              "action_kind": { "type": "string", "minLength": 1, "maxLength": 64 },
              "params_redacted": { "type": "object" },
              "result_kind": { "type": "string", "enum": ["ok", "failed", "cancelled", "skipped"] },
              "reason_codes": {
                "type": "array",
                "maxItems": 256,
                "items": { "type": "string", "minLength": 1, "maxLength": 128 }
              },
              "duration_ms": { "type": "integer", "minimum": 0, "maximum": 86400000 },
              "artifacts_refs": {
                "type": "array",
                "maxItems": 256,
                "items": { "type": "string", "minLength": 1, "maxLength": 256 }
              }
            }
          }
        }
      }
    },
    "reasons": {
      "type": "array",
      "maxItems": 8192,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "count", "first_ts", "last_ts"],
        "properties": {
          "code": { "type": "string", "minLength": 1, "maxLength": 128 },
          "severity": { "type": "string", "enum": ["info", "warn", "error"] },
          "count": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
          "first_ts": { "type": "string", "format": "date-time" },
          "last_ts": { "type": "string", "format": "date-time" }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exported_files": {
          "type": "array",
          "maxItems": 4096,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["format", "sha256", "size_bytes"],
            "properties": {
              "format": { "type": "string", "minLength": 1, "maxLength": 32 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "size_bytes": { "type": "integer", "minimum": 0, "maximum": 1099511627776 }
            }
          }
        },
        "reports": {
          "type": "array",
          "maxItems": 1024,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "ref"],
            "properties": {
              "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
              "ref": { "type": "string", "minLength": 1, "maxLength": 256 }
            }
          }
        }
      }
    },
    "consent_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["include_project_snapshot", "include_inputs_copy", "telemetry_opt_in"],
      "properties": {
        "include_project_snapshot": { "type": "boolean" },
        "include_inputs_copy": { "type": "boolean" },
        "telemetry_opt_in": { "type": "boolean" }
      }
    }
  }
}
